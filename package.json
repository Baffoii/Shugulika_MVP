{
  "name": "shugulika-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"scripts/**/*.mjs\" \"*.{ts,mjs,cjs,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"scripts/**/*.mjs\" \"*.{ts,mjs,cjs,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run src/lib",
    "test:components": "vitest run src/components",
    "test:integration": "vitest run src/test/integration",
    "test:db": "vitest run src/test/db",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "validate:env": "node scripts/validate-env.mjs",
    "db:verify": "node scripts/db-verify.mjs",
    "audit:ci": "node scripts/audit-ci.mjs",
    "ci": "npm run format:check && npm run lint && npm run typecheck && npm run validate:env && npm run test:coverage && npm run build",
    "seed:users": "node scripts/seed-users.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.8",
    "clsx": "^2.1.1",
    "lucide-react": "^1.26.0",
    "mammoth": "^1.12.0",
    "next": "^16.2.11",
    "openai": "^6.49.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "recharts": "^3.10.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.0",
    "eslint-config-next": "^16.2.11",
    "jsdom": "^26.1.0",
    "pg": "^8.22.0",
    "postcss": "^8.5.10",
    "prettier": "^3.9.6",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.9.2",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "sharp": "^0.35.3"
  }
}
