# Copy to .env.local and fill in. Only NEXT_PUBLIC_* values reach the browser.
# These two are the Supabase project URL and the frontend PUBLISHABLE (anon) key.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Base URL for auth redirect callbacks (dev default shown).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# SERVER-ONLY — used ONLY by scripts/seed-users.mjs (never reaches the browser,
# never committed). Provisions the MVP test accounts via the Supabase Admin API.
# NEVER prefix a service-role/secret key with NEXT_PUBLIC_ and never commit it.
SUPABASE_SERVICE_ROLE_KEY=

# Shared weak password for MVP demo accounts (change/remove before production).
SEED_HQ_ADMIN_PASSWORD=12345678
SEED_FRANCHISE_ADMIN_PASSWORD=12345678
SEED_OPERATIONS_ADMIN_PASSWORD=12345678
SEED_RECRUITER_PASSWORD=12345678
SEED_EMPLOYER_PASSWORD=12345678
SEED_CANDIDATE_PASSWORD=12345678
