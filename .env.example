# Copy to .env.local and fill in. Only NEXT_PUBLIC_* values reach the browser.
# These two are the Supabase project URL and the frontend PUBLISHABLE (anon) key.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Base URL for auth redirect callbacks (dev default shown).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# SERVER-ONLY — used by scripts/seed-users.mjs AND by the Next.js server for
# Storage downloads after entitlement checks (watermarked previews / HQ export).
# Never reaches the browser, never committed. NEVER prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Shared weak password for MVP demo accounts (change/remove before production).
SEED_HQ_ADMIN_PASSWORD=12345678
SEED_FRANCHISE_ADMIN_PASSWORD=12345678
SEED_OPERATIONS_ADMIN_PASSWORD=12345678
SEED_RECRUITER_PASSWORD=12345678
SEED_EMPLOYER_PASSWORD=12345678
SEED_CANDIDATE_PASSWORD=12345678

# ---------------------------------------------------------------------------
# SERVER-ONLY — used ONLY by the candidate CV/resume autofill parser (never
# reaches the browser, never committed). NEVER prefix with NEXT_PUBLIC_.
OPENAI_API_KEY=
OPENAI_RESUME_MODEL=gpt-4.1-mini
# Model for AI CV screening (role-fit reviews). Falls back to OPENAI_RESUME_MODEL.
OPENAI_SCREENING_MODEL=gpt-4.1-mini
# Optional: prepaid OpenAI credit balance in USD for the HQ AI credits remaining estimate.
# OPENAI_PREPAID_BALANCE_USD=10

# ---------------------------------------------------------------------------
# SERVER-ONLY — Resend transactional email for employer onboarding decisions
# (changes requested / approved). Omit either var to skip sending (in-app
# notifications still work). Verify the from-domain in Resend first.
RESEND_API_KEY=
EMAIL_FROM=Shugulika <onboarding@your-verified-domain.com>
