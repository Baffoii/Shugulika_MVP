# Copy to .env.local and fill in. Only NEXT_PUBLIC_* values reach the browser.
# These two are the Supabase project URL and the frontend PUBLISHABLE (anon) key.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Base URL for auth redirect callbacks (dev default shown).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# NEVER add a Supabase service-role / secret key here or in any browser-accessible
# code. If a trusted server-only secret is ever required, name it WITHOUT the
# NEXT_PUBLIC_ prefix and keep it out of version control.
